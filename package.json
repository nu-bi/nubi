{
  "name": "nubi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:full": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev\"",
    "db:reset": "cd backend && python reset_db.py",
    "db:reset:demo": "cd backend && python reset_db.py --demo",
    "build": "vite build --mode main",
    "build:dev": "vite build --mode dev",
    "build:main": "vite build --mode main",
    "build:embed": "vite build --config vite.embed.config.js",
    "build:widgets": "vite build --config vite.widgets.config.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:dash": "node --test 'src/**/*.test.mjs'",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "apache-arrow": "^21.1.0",
    "diff": "^8.0.3",
    "dompurify": "^3.2.6",
    "echarts": "^5.6.0",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.564.0",
    "papaparse": "^5.5.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-syntax-highlighter": "^16.1.0",
    "reactflow": "^11.11.4",
    "regl": "^2.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  }
}
