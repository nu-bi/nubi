# =============================================================================
# Nubi — environment variable reference
# Copy to .env (never commit .env)
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite — prefix VITE_ to expose to the browser bundle)
# -----------------------------------------------------------------------------

# Base URL of the FastAPI backend, no trailing slash.
VITE_BACKEND_URL=http://localhost:8000

# Optional: Google OAuth client ID for client-side display purposes only.
# The backend owns the full OAuth flow (PKCE + code exchange); the frontend
# does not need this to initiate sign-in (it navigates to GET /auth/google/start).
VITE_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Backend (FastAPI / pydantic-settings — loaded from .env when running uvicorn)
# -----------------------------------------------------------------------------

# Neon Postgres connection string.
# sslmode=require is mandatory for Neon; omitting it will cause connection errors.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# HS256 signing secret for JWT access tokens.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32-output

# Access token lifetime in minutes. Default: 15.
JWT_ACCESS_TTL_MIN=15

# Google OAuth 2.0 credentials.
# Create a project at https://console.cloud.google.com/apis/credentials and add
# GOOGLE_REDIRECT_URI as an authorised redirect URI in the Google Console.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# URL of the frontend (React/Vite) app.
# The backend's Google OAuth callback redirects here after a successful sign-in.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins.
# Must include every origin the frontend is served from.
CORS_ORIGINS=http://localhost:5173

# Set to false in local development (non-HTTPS) so the refresh cookie is not
# flagged Secure. Always true in staging/production.
COOKIE_SECURE=false

# Runtime environment label. Disables /docs and /redoc when set to "production".
# Values: development | test | production
ENV=development
